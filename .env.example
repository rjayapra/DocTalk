# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-51

# Azure Speech
AZURE_SPEECH_REGION=eastus2
# Use one of: AZURE_SPEECH_KEY or Azure Identity (DefaultAzureCredential)
# AZURE_SPEECH_KEY=your-speech-key

# Azure Storage
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
AZURE_STORAGE_CONTAINER_NAME=podcasts

# Phase 2: Queue and Table Storage
AZURE_STORAGE_QUEUE_NAME=podcast-jobs
AZURE_STORAGE_TABLE_NAME=podcastjobs

# Phase 2: API URL (set to enable remote mode in CLI)
# DOCTALK_API_URL=https://your-api.azurecontainerapps.io

# Phase 2: App Insights (auto-set by AZD)
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# Authentication: Uses DefaultAzureCredential locally (az login)
# In production, use Managed Identity
