# Azure Developer CLI (azd) environment values
# Copy to .env and fill in after running `azd up`
# These are auto-populated by azd — you typically don't edit them manually.

AZURE_ENV_NAME="<azd-env-name>"
AZURE_LOCATION="eastus2"
AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
AZURE_RESOURCE_GROUP="rg-<env-name>"

# Container Apps
AZURE_CONTAINER_APP_ENV_NAME="<auto-generated>"
AZURE_CONTAINER_REGISTRY_LOGIN_SERVER="<registry>.azurecr.io"
AZURE_CONTAINER_REGISTRY_NAME="<auto-generated>"

# AI Services
AZURE_OPENAI_ENDPOINT="https://<resource>.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-51"
AZURE_SPEECH_REGION="eastus2"
AZURE_SPEECH_RESOURCE_ID="<auto-generated>"

# Storage
AZURE_STORAGE_ACCOUNT_NAME="<auto-generated>"
AZURE_STORAGE_CONTAINER_NAME="podcasts"
AZURE_STORAGE_QUEUE_NAME="podcast-jobs"
AZURE_STORAGE_TABLE_NAME="podcastjobs"

# Monitoring
AZURE_KEY_VAULT_NAME="<auto-generated>"
AZURE_LOG_ANALYTICS_WORKSPACE_ID="<auto-generated>"

# API
DOCTALK_API_URL="https://<container-app-fqdn>"

# Service existence flags (set by azd)
SERVICE_API_RESOURCE_EXISTS="false"
SERVICE_WORKER_RESOURCE_EXISTS="false"
